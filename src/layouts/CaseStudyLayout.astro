---
import Layout from "./Layout.astro";
import CaseStudyNav from "../components/CaseStudyNav.astro";

type Props = {
  title: string;
  tagline: string;
  role: string;
  year?: string;
  slug: string;
};

const { title, tagline, role, year, slug } = Astro.props;
---

<Layout title={`${title} — Zach Louden`}>
  <article>
    <header class="mx-auto max-w-4xl px-6 pt-20 md:pt-32 pb-12">
      <div class="text-xs uppercase tracking-[0.2em] text-[var(--color-muted)] mb-6">
        Case Study{year ? ` · ${year}` : ""}
      </div>
      <h1 class="text-5xl md:text-7xl leading-[1.05] mb-8">{title}</h1>
      <p class="text-xl md:text-2xl text-[var(--color-muted)] leading-relaxed max-w-2xl">
        {tagline}
      </p>
      <div class="mt-10 flex flex-wrap gap-x-12 gap-y-4 text-sm">
        <div>
          <div class="uppercase tracking-[0.18em] text-[var(--color-muted)] mb-1">Role</div>
          <div>{role}</div>
        </div>
        {year && (
          <div>
            <div class="uppercase tracking-[0.18em] text-[var(--color-muted)] mb-1">Year</div>
            <div>{year}</div>
          </div>
        )}
      </div>
    </header>

    <div class="mx-auto max-w-5xl px-6 case-body">
      <slot />
    </div>

    <CaseStudyNav currentSlug={slug} />
  </article>
</Layout>

<style is:global>
  .case-body p {
    font-size: 1.125rem;
    line-height: 1.75;
    color: rgba(10, 10, 10, 0.85);
    max-width: 65ch;
    margin: 1.25rem auto;
  }
  .case-body h2 {
    font-family: var(--font-serif);
    font-size: 2rem;
    line-height: 1.2;
    margin: 3.5rem auto 1rem;
    max-width: 65ch;
  }
  .case-body h3 {
    font-family: var(--font-serif);
    font-size: 1.375rem;
    line-height: 1.3;
    margin: 2.5rem auto 0.75rem;
    max-width: 65ch;
  }
  .case-body figure {
    margin: 3rem 0;
  }
  .case-body figure img {
    width: 100%;
    height: auto;
    display: block;
    border: 1px solid var(--color-line);
    background: #fff;
  }
  .case-body figure figcaption {
    font-size: 0.85rem;
    color: var(--color-muted);
    margin-top: 0.75rem;
    text-align: center;
    max-width: 65ch;
    margin-left: auto;
    margin-right: auto;
  }
  .case-body .pullquote {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    line-height: 1.3;
    margin: 3rem auto;
    max-width: 60ch;
    color: var(--color-ink);
    border-left: 2px solid var(--color-accent);
    padding-left: 1.5rem;
  }
  .case-body ul {
    max-width: 65ch;
    margin: 1.25rem auto;
    padding-left: 1.25rem;
    list-style: disc;
    font-size: 1.0625rem;
    line-height: 1.75;
    color: rgba(10, 10, 10, 0.85);
  }
  .case-body ul li { margin: 0.4rem 0; }
</style>
