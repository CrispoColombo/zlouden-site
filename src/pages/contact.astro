---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact — Zach Louden">
  <section class="mx-auto max-w-3xl px-6 pt-20 md:pt-32 pb-24">
    <div class="text-xs uppercase tracking-[0.2em] text-[var(--color-muted)] mb-6">
      Contact
    </div>
    <h1 class="text-4xl md:text-6xl leading-tight mb-10">
      Say hello.
    </h1>
    <p class="text-lg text-[var(--color-muted)] leading-relaxed mb-12 max-w-xl">
      The fastest way to reach me is email. I'm happy to chat about product
      design, design systems, or independent engagements.
    </p>

    <div class="space-y-6 text-lg">
      <div>
        <div class="text-xs uppercase tracking-[0.18em] text-[var(--color-muted)] mb-1">Email</div>
        <a href="mailto:zlouden@gmail.com" class="underline decoration-[var(--color-line)] underline-offset-8 hover:text-[var(--color-accent)] hover:decoration-[var(--color-accent)]">
          zlouden@gmail.com
        </a>
      </div>
      <div>
        <div class="text-xs uppercase tracking-[0.18em] text-[var(--color-muted)] mb-1">LinkedIn</div>
        <a href="https://www.linkedin.com/in/zacharylouden/" target="_blank" rel="noopener noreferrer" class="underline decoration-[var(--color-line)] underline-offset-8 hover:text-[var(--color-accent)] hover:decoration-[var(--color-accent)]">
          linkedin.com/in/zacharylouden
        </a>
      </div>
      <div>
        <div class="text-xs uppercase tracking-[0.18em] text-[var(--color-muted)] mb-1">Dribbble</div>
        <a href="https://dribbble.com/zlouden" target="_blank" rel="noopener noreferrer" class="underline decoration-[var(--color-line)] underline-offset-8 hover:text-[var(--color-accent)] hover:decoration-[var(--color-accent)]">
          dribbble.com/zlouden
        </a>
      </div>
      <div>
        <div class="text-xs uppercase tracking-[0.18em] text-[var(--color-muted)] mb-1">Behance</div>
        <a href="https://www.behance.net/zlouden" target="_blank" rel="noopener noreferrer" class="underline decoration-[var(--color-line)] underline-offset-8 hover:text-[var(--color-accent)] hover:decoration-[var(--color-accent)]">
          behance.net/zlouden
        </a>
      </div>
    </div>
  </section>
</Layout>
