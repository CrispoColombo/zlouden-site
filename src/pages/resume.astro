---
import Layout from "../layouts/Layout.astro";

type Role = {
  company: string;
  title: string;
  dates: string;
  description?: string;
};

const experience: Role[] = [
  {
    company: "Independent",
    title: "Product Designer & Consultant",
    dates: "2023 — Present",
    description:
      "Designing complex SaaS UX and shipping the software myself. Currently building LintKit, a Figma design linter. Recent work spans design tooling, developer experience, and data‑heavy admin interfaces.",
  },
  {
    company: "Postman",
    title: "Product Design Lead",
    dates: "2021 — 2022",
    description:
      "UX/Product Design Team Lead for the Ecosystem Team. Managed a team of 6 product designers through multiple major releases.",
  },
  {
    company: "HashiCorp",
    title: "Senior Product Designer",
    dates: "2019 — 2020",
    description:
      "Focused on the Structure design system and Terraform Cloud — working on parity between open‑source and cloud versions, usability, and navigation.",
  },
  {
    company: "StreamSets",
    title: "Senior Product Designer",
    dates: "2018 — 2019",
    description:
      "Led the top‑down redesign of the StreamSets platform. Established the company's first design system, Richmond, with custom icons, components, and guidelines.",
  },
  {
    company: "Nuna Health",
    title: "UX Design Lead",
    dates: "2016 — 2018",
    description:
      "Design lead for tools used to transfer, error‑check, and view Medicaid data from 50 states and 7 U.S. territories (~70M lives). Presented at CMS HQ in Baltimore; the dashboard is now used by 42 states in production.",
  },
  {
    company: "CSC",
    title: "Senior UX Architect",
    dates: "2015 — 2016",
    description:
      "Led design for major enterprise clients including Mastercard (LMI) and Pfizer (HR self‑service portal).",
  },
  {
    company: "Space‑Time Insight",
    title: "UX / Product Designer",
    dates: "2014 — 2015",
    description:
      "Designed a complex logistics application for FedEx Express — a modern replacement for the 30‑year‑old TRAC and Route planning systems.",
  },
  {
    company: "Independent",
    title: "Product Designer",
    dates: "2008 — 2014",
    description:
      "Big data, SaaS, CRMs, logistics applications, and complex user interactions for a wide range of clients.",
  },
  {
    company: "X2Engine CRM",
    title: "UX / UI Designer",
    dates: "2012 — 2013",
    description:
      "Helped design an open‑source CRM that grew to 33,000+ deployments in 160 countries.",
  },
  {
    company: "Google",
    title: "UX Designer",
    dates: "2012",
    description:
      "Designed an internal CRM for the Local Marketing team and contributed to the official style guide.",
  },
  {
    company: "Cisco Systems",
    title: "UX / Visual Designer",
    dates: "2011 — 2012",
    description:
      "Redesigned Prime Security Manager and IronPort email security applications.",
  },
  {
    company: "Marketo",
    title: "UX Designer",
    dates: "2010 — 2011",
    description:
      "Designed icons, UI elements, and page layouts for a platform serving 40,000+ users.",
  },
  {
    company: "RiseSmart",
    title: "UX Designer",
    dates: "2010 — 2011",
    description:
      "Designed SaaS products from concept through implementation.",
  },
  {
    company: "Adchemy",
    title: "UX Designer",
    dates: "2009 — 2010",
    description:
      "Designed a Flex‑based SaaS application with animated UI elements in Flash and ActionScript.",
  },
];

const skills = [
  "Complex systems",
  "Interaction design",
  "Design systems",
  "Visual design",
  "Usability testing",
  "User research",
  "Information architecture",
  "Prototyping",
  "Figma",
  "HTML / CSS",
  "TypeScript",
  "React",
];

const awards = [
  {
    title: "#1 Ranked Open Source CRM",
    source: "TechRepublic, 2013",
  },
  {
    title: "BtoB Social Media Marketing Award Winner",
    source: "BtoB Magazine, 2012",
  },
  {
    title: "Forrester Groundswell Award Finalist",
    source: "Forrester, 2011",
  },
];

const languages = [
  "English (native)",
  "Russian (limited working)",
  "Spanish (limited working)",
];
---

<Layout title="Resume — Zach Louden">
  <section class="mx-auto max-w-4xl px-6 pt-20 md:pt-32 pb-24">
    <div class="text-xs uppercase tracking-[0.2em] text-[var(--color-muted)] mb-6">
      Resume
    </div>
    <h1 class="text-4xl md:text-6xl leading-tight mb-4">Zach Louden</h1>
    <p class="text-lg text-[var(--color-muted)] mb-16">
      Product Designer · San Francisco Bay Area ·
      <a href="mailto:zlouden@gmail.com" class="underline decoration-[var(--color-line)] underline-offset-4 hover:text-[var(--color-accent)]">zlouden@gmail.com</a>
    </p>

    <div class="grid md:grid-cols-[200px_1fr] gap-8 mb-16">
      <h2 class="text-sm uppercase tracking-[0.18em] text-[var(--color-muted)] pt-2">Experience</h2>
      <div class="space-y-12">
        {
          experience.map((role) => (
            <div>
              <div class="flex flex-wrap items-baseline justify-between gap-2 mb-2">
                <h3 class="text-xl leading-tight">
                  {role.title} <span class="text-[var(--color-muted)]">· {role.company}</span>
                </h3>
                <div class="text-sm text-[var(--color-muted)]">{role.dates}</div>
              </div>
              {role.description && (
                <p class="text-[var(--color-ink)]/80 leading-relaxed max-w-prose">{role.description}</p>
              )}
            </div>
          ))
        }
      </div>
    </div>

    <div class="grid md:grid-cols-[200px_1fr] gap-8 mb-16">
      <h2 class="text-sm uppercase tracking-[0.18em] text-[var(--color-muted)] pt-2">Education</h2>
      <div>
        <div class="flex flex-wrap items-baseline justify-between gap-2 mb-2">
          <h3 class="text-xl">BFA Fine Art, minor in Graphic / Web Design</h3>
          <div class="text-sm text-[var(--color-muted)]">2004 — 2008</div>
        </div>
        <p class="text-[var(--color-muted)]">Columbus College of Art & Design</p>
      </div>
    </div>

    <div class="grid md:grid-cols-[200px_1fr] gap-8 mb-16">
      <h2 class="text-sm uppercase tracking-[0.18em] text-[var(--color-muted)] pt-2">Skills</h2>
      <div class="flex flex-wrap gap-2">
        {
          skills.map((s) => (
            <span class="text-sm border border-[var(--color-line)] px-3 py-1">{s}</span>
          ))
        }
      </div>
    </div>

    <div class="grid md:grid-cols-[200px_1fr] gap-8 mb-16">
      <h2 class="text-sm uppercase tracking-[0.18em] text-[var(--color-muted)] pt-2">Honors</h2>
      <ul class="space-y-3">
        {
          awards.map((a) => (
            <li>
              <div>{a.title}</div>
              <div class="text-sm text-[var(--color-muted)]">{a.source}</div>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="grid md:grid-cols-[200px_1fr] gap-8">
      <h2 class="text-sm uppercase tracking-[0.18em] text-[var(--color-muted)] pt-2">Languages</h2>
      <ul class="space-y-2">
        {languages.map((l) => <li>{l}</li>)}
      </ul>
    </div>
  </section>
</Layout>
