---
const nav = [
  { href: "/", label: "Work" },
  { href: "/about", label: "About" },
  { href: "/resume", label: "Resume" },
  { href: "/contact", label: "Contact" },
];
const path = Astro.url.pathname;
---

<header class="border-b border-[var(--color-line)]">
  <div class="mx-auto max-w-6xl px-6 py-6 flex items-center justify-between">
    <a href="/" class="font-serif text-xl tracking-tight hover:opacity-70">
      Zach Louden
    </a>
    <nav class="flex items-center gap-8 text-sm">
      {
        nav.map((item) => {
          const active =
            item.href === "/"
              ? path === "/"
              : path.startsWith(item.href);
          return (
            <a
              href={item.href}
              class:list={[
                "hover:text-[var(--color-accent)]",
                active ? "text-[var(--color-ink)]" : "text-[var(--color-muted)]",
              ]}
            >
              {item.label}
            </a>
          );
        })
      }
    </nav>
  </div>
</header>
